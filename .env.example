# Copiar a .env.local (no subir a Git)
# Reiniciar "npm run dev" despues de cada cambio.

# --- Opcion A (RECOMENDADA): desarrollo local + backend remoto por ngrok ---
# El front llama a /api y Vite reenvia al tunel (evita CORS y paginas HTML de ngrok).
VITE_API_PROXY_TARGET=https://TU-SUBDOMINIO.ngrok-free.app
VITE_API_BASE_URL=/api

# --- Opcion B: URL directa de ngrok (tambien valida; Railway usa esta forma) ---
# VITE_API_BASE_URL=https://TU-SUBDOMINIO.ngrok-free.app/api

# --- Backend en tu misma PC ---
# VITE_API_BASE_URL=http://localhost:56398/api

# --- Backend desplegado en Railway ---
# VITE_API_BASE_URL=https://backend-facturas-production.up.railway.app/api
